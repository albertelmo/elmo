# Render에서는 Dashboard > Environment에 DATABASE_URL을 설정합니다.
# 로컬 실행 시에만 .env 파일을 만들어 쓰세요. (.gitignore에 포함됨)

# Render / 원격 Postgres
# DATABASE_URL=postgresql://user:password@host:5432/board

# 로컬 Postgres (DATABASE_URL이 없을 때)
# DB_USER=board_user
# DB_HOST=localhost
# DB_NAME=board
# DB_PASSWORD=board123
# DB_PORT=5432

# PORT=3000
